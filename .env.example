# GigaChat Credentials (get it from Sber AI console)
GIGACHAT_CREDENTIALS=your_base64_credentials_here

# GigaChat Model
GIGACHAT_MODEL=GigaChat-2-Pro

# Database
DB_PASSWORD=secure_password_here
DATABASE_URL=postgresql+asyncpg://slidewise:${DB_PASSWORD}@db:5432/slidewise

# Max file size in bytes (default: 20MB for PDFs)
MAX_FILE_SIZE=20971520

# Max PDF pages to process
MAX_PDF_PAGES=20

# Enable slide-by-slide processing (true/false)
SLIDE_BY_SLIDE=true
